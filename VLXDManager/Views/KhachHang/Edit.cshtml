@model VLXDManager.Models.KhachHang
@{
    ViewData["Title"] = "Chỉnh sửa Khách hàng";
}

@section Breadcrumb {
    <li class="breadcrumb-item"><a asp-action="Index">Khách hàng</a></li>
    <li class="breadcrumb-item active">Chỉnh sửa</li>
}

<div class="page-header">
    <div class="page-title"><i class="fas fa-user-pen text-warning me-2"></i>Chỉnh sửa: @Model.TenKH</div>
    <a asp-action="Index" class="btn btn-outline"><i class="fas fa-arrow-left"></i> Quay lại</a>
</div>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="MaKH" />
    <input type="hidden" asp-for="NgayTao" />
    <div class="row g-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <div class="card-title"><i class="fas fa-user"></i> Thông tin khách hàng</div>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label fw-600">Mã khách hàng</label>
                            <input asp-for="MaKHCode" class="form-control" readonly style="background:#f8fafc" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-600">Tên khách hàng <span class="text-danger">*</span></label>
                            <input asp-for="TenKH" class="form-control" />
                            <span asp-validation-for="TenKH" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-600">Số điện thoại</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-phone"></i></span>
                                <input asp-for="SoDienThoai" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-600">Email</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                <input asp-for="Email" class="form-control" />
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-600">Địa chỉ</label>
                            <input asp-for="DiaChi" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-600">Ghi chú</label>
                            <textarea asp-for="GhiChu" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check form-switch">
                                <input asp-for="TrangThai" class="form-check-input" type="checkbox" role="switch" />
                                <label asp-for="TrangThai" class="form-check-label fw-600">Đang hoạt động</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body d-flex flex-column gap-2">
                    <button type="submit" class="btn btn-warning w-100">
                        <i class="fas fa-save"></i> Lưu thay đổi
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.MaKH" class="btn btn-outline w-100">
                        <i class="fas fa-eye"></i> Xem chi tiết
                    </a>
                    <a asp-action="Index" class="btn btn-outline w-100">
                        <i class="fas fa-times"></i> Hủy
                    </a>
                </div>
            </div>
        </div>
    </div>
</form>
